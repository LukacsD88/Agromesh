          "jsScript": "for (var key in msg) {\r\n    // Check if key contains \"Temp\" (covers N_30EE_Temp)\r\n    if (key.indexOf(\"Temp\") !== -1) {\r\n        var val = parseFloat(msg[key]);\r\n        if (!isNaN(val) && val < 4.0) {\r\n            return true; \r\n        }\r\n    }\r\n}\r\nreturn false;",
